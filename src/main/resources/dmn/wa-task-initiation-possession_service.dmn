      <input id="InputClause_113rn1o" label="Admin Action Required" camunda:inputVariable="adminActionRequired">
        <inputExpression id="LiteralExpression_0uwx76l" typeRef="boolean">
          <text>if(additionalData != null and additionalData.Data != null and additionalData.Data.cicCaseAdminActionRequired
            != null and additionalData.Data.cicCaseAdminActionRequired = ["AdminActionRequired"]) then
            true
else
            false</text>
        </inputExpression>
      </input>
      <input id="InputClause_11t6k59" label="Has Order Due Date" camunda:inputVariable="firstOrderDueDate">
        <inputExpression id="LiteralExpression_1ylfo9b" typeRef="boolean">
          <text>if(additionalData.Data.cicCaseFirstOrderDueDate != null and additionalData.Data.cicCaseFirstOrderDueDate != "") then
  true
else
  false</text>
        </inputExpression>
      </input>
