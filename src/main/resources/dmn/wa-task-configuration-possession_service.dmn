          <text>"caseManagementCategory"</text>
        </outputEntry>
        <outputEntry id="LiteralExpression_0lofdxr">
          <text>if (caseData.caseManagementCategory !=null and caseData.caseManagementCategory.selectedLabel !=null) then caseData.caseManagementCategory.selectedLabel else "Possession Serice"</text>
