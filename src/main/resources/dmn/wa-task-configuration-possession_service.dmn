    <decisionTable id="DecisionTable_14cx079" hitPolicy="RULE ORDER">
      <input id="InputClause_1gxyo7f" label="CCD Case Data" camunda:inputVariable="caseData">
        <inputExpression id="LiteralExpression_0mra7c4" typeRef="string">
          <text></text>
