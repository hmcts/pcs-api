#!groovy

properties([
  pipelineTriggers([cron('H 07 * * 1-5')]),
  parameters([
    booleanParam(
      name: 'CHROME_TESTS',
      defaultValue: true,
      description: 'Tick to run E2E tests in Desktop Chrome.'
    ),
    booleanParam(
      name: 'FIREFOX_TESTS',
      defaultValue: false,
      description: 'Tick to run E2E tests in Desktop Firefox.'
    ),
    booleanParam(
      name: 'WEBKIT_TESTS',
      defaultValue: false,
      description: 'Tick to run E2E tests in Desktop WebKit (Safari).'
    ),
    booleanParam(
      name: 'MICROSOFT_EDGE_TESTS',
      defaultValue: false,
      description: 'Tick to run E2E tests in Microsoft Edge.'
    ),
    booleanParam(
      name: 'MOBILE_ANDROID_TESTS',
      defaultValue: false,
      description: 'Run E2E tests on the Android (Pixel 5) profile.'
    ),
    booleanParam(
      name: 'MOBILE_IOS_TESTS',
      defaultValue: false,
      description: 'Run E2E tests on the iOS (iPhone 12) WebKit profile.'
    ),
    booleanParam(
      name: 'MOBILE_IPAD_TESTS',
      defaultValue: false,
      description: 'Run E2E tests on the iPad (iPad Pro 11) WebKit profile.'
    ),
    choice(
      name: 'PLAYWRIGHT_GREP_TAG',
      choices: ['@nightly', '@smoke', '@e2e', '@crossbrowser', '(all tests)'],
      description: 'Test title grep. (all tests) = no grep. Default: @nightly.'
    ),
    string(
      name: 'PLAYWRIGHT_SPEC',
      defaultValue: '',
      description: 'Optional: comma-separated spec path keywords (e.g. searchCase,createCase). Blank = all specs under tests/.'
    ),
  ])
])

@Library("Infrastructure")

def type = "java"
def product = "pcs"
def component = "api"

static Map<String, Object> secret(String secretName, String envVariable) {
  [$class     : 'AzureKeyVaultSecret',
    secretType : 'Secret',
    name       : secretName,
    envVariable: envVariable
  ]
}

def secrets = [
  'pcs-${env}': [
    secret('pcs-api-idam-secret', 'PCS_API_IDAM_SECRET'),
    secret('idam-testing-support-url', 'IDAM_TESTING_SUPPORT_URL'),
    secret('idam-system-user-name', 'IDAM_SYSTEM_USERNAME'),
    secret('idam-system-user-password', 'IDAM_SYSTEM_USER_PASSWORD'),
    secret('idam-pcs-user-password', 'IDAM_PCS_USER_PASSWORD'),
    secret('pcs-solicitor-automation-uid', 'PCS_SOLICITOR_AUTOMATION_UID'),
    secret('pcs-prd-admin-username', 'PCS_PRD_ADMIN_USERNAME'),
    secret('pcs-prd-admin-password', 'PCS_PRD_ADMIN_PASSWORD')
  ]
]

withNightlyPipeline(type, product, component) {
  enableSlackNotifications('#qa-pipeline-status')
  loadVaultSecrets(secrets)
  handleEnvironmentSetting()
  enableFortifyScan()

  afterAlways('fortify-scan') {
    steps.archiveArtifacts allowEmptyArchive: true, artifacts: '**/Fortify Scan/**/*'
    runE2eMatrix()
  }
}

def handleEnvironmentSetting() {
  env.MANAGE_CASE_BASE_URL = 'https://manage-case.aat.platform.hmcts.net'
  env.DATA_STORE_URL_BASE = 'http://ccd-data-store-api-aat.service.core-compute-aat.internal'
  env.ENVIRONMENT = 'aat'
  def tag = params.PLAYWRIGHT_GREP_TAG ?: '@nightly'
  env.E2E_TEST_SCOPE = (tag == '(all tests)') ? '' : tag
  env.E2E_SPEC = params.PLAYWRIGHT_SPEC?.trim() ?: ''
}

def getE2eMatrix() {
  return [
    [flag: 'CHROME_TESTS', project: 'chrome', browser: 'Chrome', label: 'Desktop Chrome'],
    [flag: 'FIREFOX_TESTS', project: 'firefox', browser: 'Firefox', label: 'Desktop Firefox'],
    [flag: 'WEBKIT_TESTS', project: 'webkit', browser: 'Safari', label: 'Desktop Safari (WebKit)'],
    [flag: 'MICROSOFT_EDGE_TESTS', project: 'edge', browser: 'Edge', label: 'Desktop Edge'],
    [flag: 'MOBILE_ANDROID_TESTS', project: 'mobile-android', browser: 'MobileAndroid', label: 'Mobile Android (Pixel 5)'],
    [flag: 'MOBILE_IOS_TESTS', project: 'mobile-ios', browser: 'MobileIos', label: 'Mobile iOS (WebKit)'],
    [flag: 'MOBILE_IPAD_TESTS', project: 'mobile-ipad', browser: 'MobileIpad', label: 'Mobile iPad (WebKit)'],
  ]
}

def runE2eMatrix() {
  def e2eMatrix = getE2eMatrix()
  if (!e2eMatrix.any { row -> params[row.flag] }) {
    error('E2E matrix: enable at least one browser/device option (e.g. CHROME_TESTS).')
  }
  def gradleBuilder = new uk.gov.hmcts.contino.GradleBuilder(this, product)
  e2eMatrix.each { row ->
    if (params[row.flag]) {
      runE2eStage(gradleBuilder, row.project, row.label)
    }
  }
}

def runE2eStage(gradleBuilder, String e2eSuite, String stageLabel) {
  stage("${stageLabel}") {
    node {
      checkout scm
      sh 'rm -rf e2e-output allure-report src/e2eTest/allure-results src/e2eTest/.auth/storage-state.json || true'
      catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
        withEnv(["E2E_SUITE=${e2eSuite}"]) {
          gradleBuilder.gradle('runE2eTests')
        }
      }
      publishHTML([
        allowMissing: true,
        alwaysLinkToLastBuild: true,
        keepAll: true,
        reportDir: 'e2e-output',
        reportFiles: 'index.html',
        reportName: "${stageLabel} E2E Report"
      ])
      steps.archiveArtifacts allowEmptyArchive: true, artifacts: '**/e2e-output/**/*'
      sendAllureReportToSlack(stageLabel, e2eSuite)
    }
  }
}

def sendAllureReportToSlack(String stageLabel, String projectId) {
  env.E2E_BROWSER = stageLabel
  env.ALLURE_REPORT_PATH_SUFFIX = "Full_20${projectId}_20E2E_20Test_20Report/"
  env.E2E_SERVICE_NAME = 'pcs-api'
  env.E2E_PIPELINE_TYPE = 'nightly'
  def msg = sh(
    script: 'cd src/e2eTest && ./node_modules/.bin/tsx ./scripts/allure-slack-notifier.ts --print-only --pipeline-type nightly 2>/dev/null || true',
    returnStdout: true
  ).trim()
  if (!msg) {
    msg = "E2E Test Results — Build #${env.BUILD_NUMBER} — See ${env.BUILD_URL} for details"
  }
  try {
    slackSend(channel: '#qa-pipeline-status', message: msg)
    echo "E2E Slack notification sent to #qa-pipeline-status (${stageLabel})"
  } catch (Exception e) {
    echo "WARNING: Slack notification failed: ${e.message}"
  }
}
