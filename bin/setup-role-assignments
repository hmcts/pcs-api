#!/usr/bin/env bash
set -eu

BASEDIR=$(dirname "$0")

# staff-emails.json lists the AAT test caseworker accounts to seed org role mappings for (the
# source of truth is the "Test Users" Confluence page in the RRFM space). Bail before fetching any
# credentials or leasing tokens when there is nothing to seed.
EMAIL_FILE="${BASEDIR}/staff-emails.json"
if ! [[ -f "${EMAIL_FILE}" ]] || ! jq -e '.userEmails | length > 0' "${EMAIL_FILE}" >/dev/null 2>&1; then
  echo "No userEmails in ${EMAIL_FILE} — skipping org role mapping setup"
  exit 0
fi

# In the pipeline these credentials are injected as env vars by loadVaultSecrets (the ccd-${env}
# and pcs-${env} vault blocks in Jenkinsfile_CNP). To run locally, uncomment the lines below to read
# them from the key vault yourself (requires `az login`):
#IDAM_DATA_STORE_SYSTEM_USER_USERNAME=$(az keyvault secret show --vault-name ccd-aat -o tsv --query value --name idam-data-store-system-user-username)
#IDAM_DATA_STORE_SYSTEM_USER_PASSWORD=$(az keyvault secret show --vault-name ccd-aat -o tsv --query value --name idam-data-store-system-user-password)
#export CCD_API_GATEWAY_IDAM_CLIENT_SECRET=$(az keyvault secret show --vault-name ccd-aat -o tsv --query value --name ccd-api-gateway-oauth2-client-secret)
#export IDAM_PCS_USER_PASSWORD=$(az keyvault secret show --vault-name pcs-aat -o tsv --query value --name idam-pcs-user-password)

ORG_ROLE_MAPPING_SERVICE_URL=${ORG_ROLE_MAPPING_SERVICE_URL:-http://am-org-role-mapping-service-aat.service.core-compute-aat.internal}
export IDAM_API_BASE_URL=${IDAM_API_BASE_URL:-https://idam-api.aat.platform.hmcts.net}

S2S_TOKEN=$(${BASEDIR}/s2s-token.sh "am_org_role_mapping_service")
IDAM_TOKEN=$(${BASEDIR}/idam-user-token.sh "${IDAM_DATA_STORE_SYSTEM_USER_USERNAME}" "${IDAM_DATA_STORE_SYSTEM_USER_PASSWORD}")

# Resolve each test-user email to its IDAM user id. The shared admin user-search endpoint
# (/api/v1/users) is role-gated and our system user is forbidden, but every user can read its own
# id from /o/userinfo — so we log in as each test user (all share IDAM_PCS_USER_PASSWORD) and read
# back its uid. Emails that fail to authenticate are warned about and skipped rather than failing
# the whole seed.
function resolve_user_ids() {
  local email_file=$1
  local ids=()
  local email token uid

  while IFS= read -r email; do
    token=$(${BASEDIR}/idam-user-token.sh "${email}" "${IDAM_PCS_USER_PASSWORD}" 2>/dev/null || true)
    if [[ -z "${token}" ]]; then
      >&2 echo "WARNING: could not authenticate ${email} — skipping"
      continue
    fi
    uid=$(curl --silent --fail -H "Authorization: Bearer ${token}" \
      "${IDAM_API_BASE_URL}/o/userinfo" | jq -r '.uid' 2>/dev/null || true)
    if [[ -z "${uid}" || "${uid}" == "null" ]]; then
      >&2 echo "WARNING: could not resolve uid for ${email} — skipping"
      continue
    fi
    ids+=("${uid}")
  done < <(jq -r '.userEmails[]' "${email_file}")

  if [[ ${#ids[@]} -eq 0 ]]; then
    echo '{"userIds":[]}'
    return
  fi
  printf '%s\n' "${ids[@]}" | jq -R . | jq -s '{userIds: .}'
}

function send_curl_request() {
  local payload=$1
  local user_type=$2

  local url="${ORG_ROLE_MAPPING_SERVICE_URL}/am/testing-support/createOrgMapping?userType=${user_type}"

  curl --silent --show-error --fail "${url}" \
  -H 'Content-Type: application/json' \
  -H "Authorization: Bearer ${IDAM_TOKEN}" \
  -H "ServiceAuthorization: ${S2S_TOKEN}" \
  -d "${payload}"
}

CASEWORKER_PAYLOAD=$(resolve_user_ids "${EMAIL_FILE}")

if [[ "$(jq '.userIds | length' <<<"${CASEWORKER_PAYLOAD}")" -eq 0 ]]; then
  echo "No user ids could be resolved from ${EMAIL_FILE} — nothing to seed"
  exit 0
fi

send_curl_request "${CASEWORKER_PAYLOAD}" "CASEWORKER"
