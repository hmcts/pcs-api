      "epimms_id": {
        "matches": "\\d+"
      },
      "service_code": {
        "equalTo": "AAA3"
      }
    }
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "transformers": [
      "response-template"
    ],
    "jsonBody": [
      {
        "court_location_id": "123",
